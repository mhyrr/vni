<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Vote No Incumbents" suffix=" · VNI">
      {assigns[:page_title]}
    </.live_title>
    <meta
      name="description"
      content="See how congressional districts entrench power—and what it would take to vote every incumbent out."
    />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="bg-[var(--paper)] text-[var(--ink)] antialiased">
    {@inner_content}
  </body>
</html>
